{
    "name": "rust-cargo",
    "version": "1.0.1",
    "private": false,
    "description": "Run cargo command",
    "main": "lib/main.js",
    "directories": {
        "lib": "lib",
        "test": "__tests__"
    },
    "scripts": {
        "bundle": "cp -r .matchers ./dist/",
        "build": "rm -rf ./dist/* && ncc build src/main.ts --minify && npm run bundle",
        "format": "prettier --write 'src/**/*.ts' '__tests__/**/*.ts'",
        "lint": "tsc --noEmit && eslint 'src/**/*.ts' '__tests__/**/*.ts'",
        "watch": "rm -rf ./dist/* && ncc build src/main.ts --watch",
        "test": "jest -c jest.config.json"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/step-security/actions-rs-cargo.git"
    },
    "keywords": [
        "actions",
        "rust",
        "cargo"
    ],
    "author": "step-security",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/step-security/actions-rs-cargo/issues"
    },
    "dependencies": {
        "@actions/core": "^2.0.3",
        "@actions/exec": "^2.0.0",
        "@actions/io": "^3.0.2",
        "axios": "^1.16.0",
        "string-argv": "^0.3.1"
    },
    "devDependencies": {
        "@types/jest": "^29.5.0",
        "@types/node": "^24.0.0",
        "@typescript-eslint/eslint-plugin": "^4.0.0",
        "@typescript-eslint/parser": "^4.0.0",
        "@vercel/ncc": "^0.38.4",
        "eslint": "^7.29.0",
        "eslint-config-prettier": "^7.2.0",
        "eslint-plugin-prettier": "^3.4.0",
        "jest": "^29.7.0",
        "jest-circus": "^29.7.0",
        "npm-check-updates": "^22.2.3",
        "prettier": "^2.2.1",
        "ts-jest": "^29.1.0",
        "typescript": "^5.9.0"
    }
}
